{
  "appId": "jp.ac.kagawa-u.eng.kj.mdp",
  "productName": "MDP",
  "disableDefaultIgnoredFiles": true,
  "directories": {
    "app": ".",
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "app/main.cjs",
    "app/preload.cjs",
    "app/remoteRelay.cjs",
    "app/remoteServer.cjs",
    "app/mdplink.cjs",
    "app/mcp-bridge.cjs",
    "app/mcp-server.cjs",
    "node_modules/ws/**/*",
    "node_modules/ssh2/**/*",
    "node_modules/asn1/**/*",
    "node_modules/safer-buffer/**/*",
    "node_modules/bcrypt-pbkdf/**/*",
    "node_modules/tweetnacl/**/*",
    "../server.cjs",
    "build/icon.*"
  ],
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "build/icon.png"
  },
  "nsis": {
    "uninstallDisplayName": "MDP"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "build/icon.png",
    "category": "public.app-category.productivity"
  },
  "dmg": {
    "title": "MDP Install",
    "iconSize": 128,
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "asarUnpack": [
    "app/mcp-server.cjs"
  ]
}
