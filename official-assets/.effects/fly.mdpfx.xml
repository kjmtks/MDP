    .mdp-effect.fly[data-mdp-phase="leave"]        { opacity: 1; transform: translateY(0); }
    .mdp-effect.fly[data-mdp-phase="leave-active"] { opacity: 0; transform: translateY(-30px); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
