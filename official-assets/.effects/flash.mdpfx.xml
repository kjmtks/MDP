<effect>
  <name>flash</name>
  <description>Opacity flicker for emphasis. Falls back to a fade when used as a transition. Works as an emphasis, a slide transition, and a build (enter/exit).</description>
  <parameters>
    <param name="duration" default="400" />
    <param name="easing" default="ease" />
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: flash</label>
      <text><![CDATA[<!-- @transition flash -->]]></text>
      <description>Fade into this slide (flash is best used as an emphasis).</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: flash (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: flash -->
content
<!-- @end -->]]></text>
      <description>Emphasize a range at a build step with an opacity flicker.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.flash[data-mdp-phase="enter"]        { opacity: 0; }
    .mdp-effect.flash[data-mdp-phase="enter-active"] { opacity: 1; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.flash[data-mdp-phase="leave"]        { opacity: 1; }
    .mdp-effect.flash[data-mdp-phase="leave-active"] { opacity: 0; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.flash[data-mdp-phase="emphasis-active"] { animation: mdp-flash var(--mdp-fx-duration) var(--mdp-fx-easing); }
    @keyframes mdp-flash {
      0%   { opacity: 1; }
      25%  { opacity: 0.2; }
      50%  { opacity: 1; }
      75%  { opacity: 0.2; }
      100% { opacity: 1; }
    }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
