<module>
  <name>label</name>
  <type>inline</type>
  <description>An outlined tag/label</description>

  <parameters>
    <param name="text" required="true" />
    <param name="color" default="var(--accent-color)" required="false" />
  </parameters>

  <snippets>
    <snippet>
      <category>UI Parts</category>
      <label>Label</label>
      <text><![CDATA[<!-- @label text: New, color: var(--accent-color) -->]]></text>
      <description>Outlined tag with transparent background</description>
    </snippet>
  </snippets>

  <render><![CDATA[
    const color = args.color || 'var(--accent-color)';
    return `<span class="mdp-mod-label" style="color: ${color}; border-color: ${color};">${args.text}</span>`;
  ]]></render>

  <style><![CDATA[
    .mdp-mod-label {
      display: inline-block;
      padding: 1px 9px;
      font-size: 0.8em;
      font-weight: 600;
      line-height: 1.4;
      background-color: transparent;
      border: 1.5px solid;
      border-radius: 9999px;
      vertical-align: middle;
    }
  ]]></style>

  <script></script>
</module>
