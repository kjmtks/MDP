<effect>
  <name>blur</name>
  <description>Blur in/out. The element fades from a soft blur into focus. Works as a slide transition and as a build (enter/exit).</description>
  <aiSpec><![CDATA[
Content defocuses from a soft blur into sharp focus (and back out on leave), combined with a fade.
Works both as a slide transition and as a build enter/exit. Dreamy and a touch cinematic, slightly
heavier than a plain fade. Choose it when you want a soft, atmospheric reveal rather than a neutral
cut; prefer fade for the most subtle, default option.
]]></aiSpec>
  <parameters>
    <param name="duration" type="number" default="400" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: blur</label>
      <text><![CDATA[<!-- @transition blur -->]]></text>
      <description>Blur into focus when entering this slide.</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: blur (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: blur -->
content
<!-- @end -->]]></text>
      <description>Reveal a range at a build step with a blur-in.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.blur[data-mdp-phase="enter"]        { opacity: 0; filter: blur(12px); }
    .mdp-effect.blur[data-mdp-phase="enter-active"] { opacity: 1; filter: blur(0); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), filter var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.blur[data-mdp-phase="leave"]        { opacity: 1; filter: blur(0); }
    .mdp-effect.blur[data-mdp-phase="leave-active"] { opacity: 0; filter: blur(12px); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), filter var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
