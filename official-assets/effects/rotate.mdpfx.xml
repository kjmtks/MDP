<effect>
  <name>rotate</name>
  <description>Rotate and scale in. The element spins slightly and grows into place while fading in. Works as a slide transition and as a build (enter/exit).</description>
  <parameters>
    <param name="duration" type="number" default="400" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: rotate</label>
      <text><![CDATA[<!-- @transition rotate -->]]></text>
      <description>Rotate and scale into this slide.</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: rotate (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: rotate -->
content
<!-- @end -->]]></text>
      <description>Reveal a range at a build step with a rotate-in.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.rotate[data-mdp-phase="enter"]        { opacity: 0; transform: rotate(-8deg) scale(0.9); }
    .mdp-effect.rotate[data-mdp-phase="enter-active"] { opacity: 1; transform: rotate(0deg) scale(1); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.rotate[data-mdp-phase="leave"]        { opacity: 1; transform: rotate(0deg) scale(1); }
    .mdp-effect.rotate[data-mdp-phase="leave-active"] { opacity: 0; transform: rotate(-8deg) scale(0.9); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
