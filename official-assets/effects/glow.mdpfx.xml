<effect>
  <name>glow</name>
  <description>Pulsing accent-colored glow for emphasis. Falls back to a fade when used as a transition. Works as an emphasis, a slide transition, and a build (enter/exit).</description>
  <parameters>
    <param name="duration" default="400" />
    <param name="easing" default="ease" />
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: glow</label>
      <text><![CDATA[<!-- @transition glow -->]]></text>
      <description>Fade into this slide (glow is best used as an emphasis).</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: glow (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: glow -->
content
<!-- @end -->]]></text>
      <description>Emphasize a range at a build step with a pulsing glow.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.glow[data-mdp-phase="enter"]        { opacity: 0; }
    .mdp-effect.glow[data-mdp-phase="enter-active"] { opacity: 1; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.glow[data-mdp-phase="leave"]        { opacity: 1; }
    .mdp-effect.glow[data-mdp-phase="leave-active"] { opacity: 0; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.glow[data-mdp-phase="emphasis-active"] { animation: mdp-glow var(--mdp-fx-duration) var(--mdp-fx-easing); }
    @keyframes mdp-glow {
      0%   { box-shadow: 0 0 0 rgba(0, 0, 0, 0); filter: drop-shadow(0 0 0 var(--accent-color, #3b82f6)); }
      50%  { box-shadow: 0 0 24px var(--accent-color, #3b82f6); filter: drop-shadow(0 0 12px var(--accent-color, #3b82f6)); }
      100% { box-shadow: 0 0 0 rgba(0, 0, 0, 0); filter: drop-shadow(0 0 0 var(--accent-color, #3b82f6)); }
    }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
