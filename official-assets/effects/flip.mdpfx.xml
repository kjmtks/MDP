<effect>
  <name>flip</name>
  <description>3D flip around the Y axis. Works as a slide transition or a build.</description>
  <parameters>
    <param name="duration" type="number" default="500" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease-in-out" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: flip</label>
      <text><![CDATA[<!-- @transition flip -->]]></text>
      <description>Flip into this slide.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.flip[data-mdp-phase="enter"]        { opacity: 0; transform: perspective(1200px) rotateY(90deg); }
    .mdp-effect.flip[data-mdp-phase="enter-active"] { opacity: 1; transform: perspective(1200px) rotateY(0deg); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.flip[data-mdp-phase="leave"]        { opacity: 1; transform: perspective(1200px) rotateY(0deg); }
    .mdp-effect.flip[data-mdp-phase="leave-active"] { opacity: 0; transform: perspective(1200px) rotateY(-90deg); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
