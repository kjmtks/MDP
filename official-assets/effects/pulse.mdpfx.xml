<effect>
  <name>pulse</name>
  <description>A one-shot scale pulse — intended for build emphasis.</description>
  <tags>emphasis, subtle</tags>
  <aiSpec><![CDATA[
A single gentle scale-up-and-back "heartbeat". Attention effect — use as a build
emphasis to draw the eye to existing content without moving it around. Subtler than
tada or shake. Not suited as a slide transition.
]]></aiSpec>
  <parameters>
    <param name="duration" type="number" default="500" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease-in-out" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Builds</category>
      <label>Build: emphasis pulse</label>
      <text><![CDATA[<!-- @build enter: 1, emphasis: 2, emphasisEffect: pulse -->
content
<!-- @end -->]]></text>
      <description>Reveal at step 1, then pulse for emphasis at step 2.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    @keyframes mdp-effect-pulse {
      0%   { transform: scale(1); }
      50%  { transform: scale(1.08); }
      100% { transform: scale(1); }
    }
    .mdp-effect.pulse[data-mdp-phase="emphasis-active"] { animation: mdp-effect-pulse var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
