<effect>
  <name>wipe</name>
  <description>Reveal with a left-to-right clip wipe.</description>
  <tags>transition, reveal, mask</tags>
  <aiSpec><![CDATA[
A hard clip edge sweeps left-to-right to reveal, then off to the right to leave — clean
and directional, no fade or movement. Strong as a slide transition; also fine as a
build enter/exit. Very close to reveal; choose either for an editorial, "swept-in" look.
]]></aiSpec>
  <parameters>
    <param name="duration" type="number" default="450" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: wipe</label>
      <text><![CDATA[<!-- @transition wipe -->]]></text>
      <description>Wipe into this slide.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.wipe[data-mdp-phase="enter"]        { clip-path: inset(0 100% 0 0); }
    .mdp-effect.wipe[data-mdp-phase="enter-active"] { clip-path: inset(0 0 0 0); transition: clip-path var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.wipe[data-mdp-phase="leave"]        { clip-path: inset(0 0 0 0); }
    .mdp-effect.wipe[data-mdp-phase="leave-active"] { clip-path: inset(0 0 0 100%); transition: clip-path var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
