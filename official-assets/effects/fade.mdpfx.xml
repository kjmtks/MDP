<effect>
  <name>fade</name>
  <description>Cross-fade. Works as a slide transition and as a build (enter/exit).</description>
  <tags>transition, subtle</tags>
  <aiSpec><![CDATA[
Soft opacity cross-fade with no motion or directional bias. The most subtle, neutral option and a
safe default for both slide transitions and build enter/exit. Choose it whenever you want a clean,
calm reveal that does not distract from content; pick a directional or physical effect (slide, drop,
zoom) only when you specifically want visible motion.
]]></aiSpec>
  <parameters>
    <param name="duration" type="number" default="400" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: fade</label>
      <text><![CDATA[<!-- @transition fade -->]]></text>
      <description>Cross-fade into this slide.</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: fade (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: fade -->
content
<!-- @end -->]]></text>
      <description>Reveal a range at a build step with a fade.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.fade[data-mdp-phase="enter"]        { opacity: 0; }
    .mdp-effect.fade[data-mdp-phase="enter-active"] { opacity: 1; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.fade[data-mdp-phase="leave"]        { opacity: 1; }
    .mdp-effect.fade[data-mdp-phase="leave-active"] { opacity: 0; transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
