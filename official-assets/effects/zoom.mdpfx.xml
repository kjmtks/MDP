<effect>
  <name>zoom</name>
  <description>Scale + fade. Works as a slide transition and as a build.</description>
  <aiSpec><![CDATA[
Content fades up while growing slightly into place (and scales past on exit) — a smooth,
focusing "push-in". Works well as a slide transition and as a build enter/exit. A safe,
near-neutral choice with a touch more depth than a plain fade; not direction-aware.
]]></aiSpec>
  <parameters>
    <param name="duration" type="number" default="400" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: zoom</label>
      <text><![CDATA[<!-- @transition zoom -->]]></text>
      <description>Zoom into this slide.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.zoom[data-mdp-phase="enter"]        { opacity: 0; transform: scale(0.8); }
    .mdp-effect.zoom[data-mdp-phase="enter-active"] { opacity: 1; transform: scale(1); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.zoom[data-mdp-phase="leave"]        { opacity: 1; transform: scale(1); }
    .mdp-effect.zoom[data-mdp-phase="leave-active"] { opacity: 0; transform: scale(1.2); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
