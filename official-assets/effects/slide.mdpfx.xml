<effect>
  <name>slide</name>
  <description>Horizontal slide. As a transition it follows the navigation direction (forward/back).</description>
  <parameters>
    <param name="duration" type="number" default="450" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: slide</label>
      <text><![CDATA[<!-- @transition slide -->]]></text>
      <description>Slide horizontally into this slide.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.slide[data-mdp-phase="enter"][data-mdp-dir="back"]    { transform: translateX(-100%); }
    .mdp-effect.slide[data-mdp-phase="enter"]                         { transform: translateX(100%); }
    .mdp-effect.slide[data-mdp-phase="enter-active"]                  { transform: translateX(0); transition: transform var(--mdp-fx-duration) var(--mdp-fx-easing); }

    .mdp-effect.slide[data-mdp-phase="leave"]                         { transform: translateX(0); }
    .mdp-effect.slide[data-mdp-phase="leave-active"][data-mdp-dir="back"] { transform: translateX(100%);  transition: transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.slide[data-mdp-phase="leave-active"]                  { transform: translateX(-100%); transition: transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
