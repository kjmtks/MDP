<effect>
  <name>glide</name>
  <description>Gentle horizontal glide with a fade. The element eases in from the right and leaves to the left. Softer than the hard slide. Works as a slide transition and as a build (enter/exit).</description>
  <parameters>
    <param name="duration" type="number" default="400" label="Duration (ms)" desc="Animation length in milliseconds" min="0" integer="true" />
    <param name="easing" type="select" default="ease" label="Easing">
      <option value="ease" label="Ease" />
      <option value="linear" label="Linear" />
      <option value="ease-in" label="Ease in" />
      <option value="ease-out" label="Ease out" />
      <option value="ease-in-out" label="Ease in-out" />
      <option value="cubic-bezier(0.34, 1.56, 0.64, 1)" label="Overshoot" />
      <option value="cubic-bezier(0.68, -0.55, 0.27, 1.55)" label="Anticipate" />
    </param>
  </parameters>
  <snippets>
    <snippet>
      <category>Transitions</category>
      <label>Transition: glide</label>
      <text><![CDATA[<!-- @transition glide -->]]></text>
      <description>Glide gently into this slide.</description>
    </snippet>
    <snippet>
      <category>Builds</category>
      <label>Build: glide (step)</label>
      <text><![CDATA[<!-- @build step: 1, effect: glide -->
content
<!-- @end -->]]></text>
      <description>Reveal a range at a build step with a gentle glide.</description>
    </snippet>
  </snippets>
  <style><![CDATA[
    .mdp-effect.glide[data-mdp-phase="enter"]        { opacity: 0; transform: translateX(60px); }
    .mdp-effect.glide[data-mdp-phase="enter-active"] { opacity: 1; transform: translateX(0); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
    .mdp-effect.glide[data-mdp-phase="leave"]        { opacity: 1; transform: translateX(0); }
    .mdp-effect.glide[data-mdp-phase="leave-active"] { opacity: 0; transform: translateX(-60px); transition: opacity var(--mdp-fx-duration) var(--mdp-fx-easing), transform var(--mdp-fx-duration) var(--mdp-fx-easing); }
  ]]></style>
  <script><![CDATA[]]></script>
</effect>
