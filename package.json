{
  "name": "mdp",
  "version": "1.3.18",
  "description": "Markdown Presentation Editor",
  "author": "Takeshi Kojima",
  "type": "module",
  "main": "app/main.cjs",
  "scripts": {
    "postinstall": "node scripts/download-drawio.cjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "node server.cjs",
    "electron:dev": "npm run build && concurrently \"vite build --watch\" \"cross-env NODE_ENV=development electron .\"",
    "electron:start": "cross-env NODE_ENV=production electron .",
    "electron:build": "npm run build && electron-builder",
    "generate-icons": "npm run gen-app-icon && npm run gen-favicons",
    "gen-app-icon": "npx svgexport build/icon-filled.svg build/icon.png 1024:1024",
    "gen-favicons": "npx svgexport build/icon-filled.svg public/favicon/android-chrome-192x192.png 192:192 && npx svgexport build/icon-filled.svg public/favicon/android-chrome-512x512.png 512:512 && npx svgexport build/icon-filled.svg public/favicon/apple-touch-icon.png 180:180 && npx svgexport build/icon-filled.svg public/favicon/favicon-32x32.png 32:32 && npx svgexport build/icon-filled.svg public/favicon/favicon-16x16.png 16:16 && npx svgexport build/icon-filled.svg public/favicon/favicon.ico 32:32"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@plantuml/core": "^1.2026.5",
    "@uiw/codemirror-extensions-langs": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.4",
    "chart.js": "^4.5.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dockview": "^6.6.1",
    "dompurify": "^3.3.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jsqr": "^1.4.0",
    "katex": "^0.16.27",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "marked-katex-extension": "^5.1.6",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^4.10.38",
    "plantuml-encoder": "^1.4.0",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.4.1",
    "react-router-dom": "^7.16.0",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.4",
    "@types/plantuml-encoder": "^1.4.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.3",
    "vite-plugin-node-polyfills": "^0.28.0",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "esbuild@0.27.2": true,
    "electron-winstaller@5.4.0": true
  }
}
